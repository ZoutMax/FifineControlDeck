#!/bin/bash
# Push-to-talk dictation for the fifine deck (or any hotkey).
#
# First press:  starts recording from the default microphone.
# Second press: stops, transcribes locally (Whisper on the GPU), and TYPES
#               the text into the focused window (ydotool, Wayland-safe).
#
#   fifine-dictate            toggle record/transcribe+type
#   fifine-dictate --dry-run  transcribe but print to stdout instead of typing
#
# All local: audio never leaves this machine.
set -u
DIR="$HOME/.local/share/fifine-dictation"
SOCK=/tmp/fifine-dictate.sock
WAV=/tmp/fifine-dictate.wav
PIDFILE=/tmp/fifine-dictate.pid
DRY="${1:-}"

ensure_server() {
    if [ ! -S "$SOCK" ] || ! python3 - << 'PY' 2>/dev/null
import socket
s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
s.settimeout(1)
s.connect("/tmp/fifine-dictate.sock")
s.close()
PY
    then
        nohup "$DIR/venv/bin/python" "$DIR/server.py" > /tmp/fifine-dictate-server.log 2>&1 &
        for _ in $(seq 1 60); do [ -S "$SOCK" ] && break; sleep 0.5; done
    fi
}

if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
    # ---- second press: stop + transcribe + type -------------------------
    kill "$(cat "$PIDFILE")" 2>/dev/null
    rm -f "$PIDFILE"
    # No ticker is started any more (see the comment further down), but a
    # session begun by an older copy of this script may still have one.
    [ -f /tmp/fifine-dictate.tick ] && kill "$(cat /tmp/fifine-dictate.tick)" 2>/dev/null
    rm -f /tmp/fifine-dictate.tick
    if [ -f /tmp/fifine-dictate.notifid ]; then
        gdbus call --session --dest org.freedesktop.Notifications \
            --object-path /org/freedesktop/Notifications \
            --method org.freedesktop.Notifications.CloseNotification \
            "$(cat /tmp/fifine-dictate.notifid)" >/dev/null 2>&1 || true
        rm -f /tmp/fifine-dictate.notifid
    fi
    sleep 0.3                       # let the wav flush
    TEXT=$(python3 - "$WAV" << 'PY'
import socket, sys
s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
s.settimeout(120)
s.connect("/tmp/fifine-dictate.sock")
s.sendall((sys.argv[1] + "\n").encode())
buf = b""
while not buf.endswith(b"\n"):
    chunk = s.recv(4096)
    if not chunk:
        break
    buf += chunk
print(buf.decode().strip())
PY
    )
    if [ -z "$TEXT" ]; then
        spd-say -r -20 "I did not catch that."
        exit 0
    fi
    if [ "${#TEXT}" -gt 600 ]; then
        # A runaway recording produced an essay: never type it blindly into
        # the focused window. Park it in a file instead.
        printf '%s\n' "$TEXT" > /tmp/fifine-dictate-last.txt
        spd-say -r -20 "That was very long. I saved it to a file instead of typing it."
        exit 0
    fi
    if [ "$DRY" = "--dry-run" ]; then
        echo "$TEXT"
    else
        printf '%s' "$TEXT" | ydotool type --file /dev/stdin
        # auto-send: press Enter after the text (28 = KEY_ENTER), unless
        # dictating into a document where a newline would be unwanted
        case "$*" in *--no-enter*) ;; *) ydotool key 28:1 28:0 ;; esac
    fi
else
    # ---- first press: start recording -----------------------------------
    ensure_server                    # warm the model while the user talks
    rm -f "$WAV"
    spd-say -w -r -10 "listening"    # cue BEFORE recording starts (blocks)
    # spd-say returns when synthesis ends, not when the speaker is quiet. On
    # a speakerphone the tail of the cue lands in the recording and Whisper
    # transcribes it, so give the room a moment to settle.
    sleep 0.4
    timeout 90 parecord --format=s16le --rate=16000 --channels=1 "$WAV" &
    echo $! > "$PIDFILE"
    # Visible recording state (the deck key itself cannot change colour
    # without app support): a sticky red notification, closed on the second
    # press and when the 90 s cap fires.
    #
    # Deliberately SILENT. An earlier version ticked every 15 s so a
    # forgotten recording was never silent, but on a speakerphone-style mic
    # (Jabra and friends) the microphone sits beside the loudspeaker and
    # records the ticks, which Whisper then transcribes as invented words.
    # The 90 s auto-stop is the runaway guard instead.
    notify-send --print-id -u critical -t 0 "🔴 Recording" \
        "Dictation is listening — press Talk again to stop (auto-stops at 90 s)" \
        > /tmp/fifine-dictate.notifid 2>/dev/null || true
fi
